rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); } // Simplified for prototype to avoid email verification blocks
    function isAdmin() { 
      return isSignedIn() && (
             request.auth.token.email == 'riteshgarad4@gmail.com' ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin')
      );
    }
    function isDeptHead(dept) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Dept Head' || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Department Head') &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department == dept;
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'recipientId', 'timestamp', 'read']) &&
             data.keys().size() == 6 &&
             data.text is string && data.text.size() <= 3000 &&
             data.senderId == request.auth.uid &&
             data.senderName is string &&
             data.recipientId is string &&
             data.timestamp == request.time &&
             data.read == false;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn(); 
      allow create: if isAdmin() || (
        isVerified() && isOwner(userId) && 
        incoming().keys().hasAll(['uid', 'email', 'name', 'role', 'department', 'isActive', 'createdAt']) &&
        (incoming().role == 'Volunteer' || incoming().role == 'Staff Operative' || request.auth.token.email == 'riteshgarad4@gmail.com')
      );
      allow update: if isAdmin() || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'department', 'isActive']));
      allow delete: if isAdmin();

      match /notifications/{notifId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin() || isDeptHead('Finance') || isDeptHead('HR') || isDeptHead('Operations');
      }
    }

    // --- Projects ---
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isVerified(); 
      allow update: if (
        isAdmin() || 
        (isDeptHead(existing().department) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'budget_status', 'rejection_reason'])) ||
        (isOwner(existing().creator_id) && existing().status == 'pending_dept_review' && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'budget', 'department', 'lead_name']))
      );
      allow delete: if isAdmin();
      
      match /milestones/{milestoneId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isDeptHead(get(/databases/$(database)/documents/projects/$(projectId)).data.department);
      }
    }

    // --- Tasks ---
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isVerified();
      allow update: if isVerified() && (
        isAdmin() || 
        isDeptHead(existing().assignedDept) ||
        (isOwner(existing().assignedVolunteerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'completedAt', 'relatedDocId']))
      );
      allow delete: if isAdmin();
    }

    // --- Volunteers ---
    match /volunteers/{volunteerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Documentation ---
    match /documents/{docId} {
      allow read: if isSignedIn();
      allow create: if isVerified();
      allow update: if (
        isAdmin() || 
        isDeptHead('Operations') || 
        isDeptHead('Marketing') ||
        (isOwner(existing().uploaderId) && existing().status == 'pending')
      );
      allow delete: if isAdmin() || (isSignedIn() && existing().uploaderId == request.auth.uid);
    }

    // --- Finance & Transactions ---
    match /finance/{fId} {
      allow read: if isAdmin() || isDeptHead('Finance');
      allow create: if isAdmin() || isDeptHead('Finance');
    }

    match /transactions/{tId} {
      allow read: if isAdmin() || isDeptHead('Finance');
      allow create: if isAdmin() || isDeptHead('Finance') || isDeptHead('Operations');
      allow update: if isAdmin() || isDeptHead('Finance');
    }

    match /finance_requests/{rId} {
      allow read, write: if isAdmin() || isDeptHead('Finance');
    }

    match /expense_requests/{rId} {
      allow list: if isAdmin() || isDeptHead('Finance') || (isSignedIn() && resource.data.requesterId == request.auth.uid);
      allow get: if isAdmin() || isDeptHead('Finance') || (isSignedIn() && resource.data.requesterId == request.auth.uid);
      allow update, delete: if isAdmin() || isDeptHead('Finance') || (isSignedIn() && existing().requesterId == request.auth.uid);
      allow create: if isVerified();
    }

    match /budget_requests/{rId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isDeptHead('Finance') || isDeptHead(incoming().department);
    }

    // --- Campaigns ---
    match /campaigns/{cId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isDeptHead('Marketing') || isDeptHead('Social Media') || isDeptHead('Public Relations');
    }

    // --- Donors & Donations ---
    match /donors/{dId} {
      allow read: if isAdmin() || isDeptHead('Finance') || isDeptHead('Public Relations');
      allow write: if isAdmin() || isDeptHead('Finance');
    }

    match /donations/{dId} {
      allow read: if isAdmin() || isDeptHead('Finance');
      allow create: if isVerified();
    }

    // --- Misc ---
    match /activity_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /automation_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only server via Admin SDK can write
    }
    
    match /work_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isVerified();
      allow update: if isAdmin() || isDeptHead(existing().department);
    }

    match /volunteer_applications/{appId} {
      allow read: if isAdmin() || isDeptHead('HR');
      allow create: if true; // Public access
      allow update: if isAdmin() || isDeptHead('HR');
    }

    match /volunteer_certificates/{certId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isDeptHead('HR');
    }

    match /messages/{messageId} {
      allow list: if isSignedIn() && (
        isAdmin() ||
        resource.data.recipientId == 'global' || 
        resource.data.recipientId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        isAdmin() ||
        resource.data.recipientId == 'global' || 
        resource.data.recipientId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
      allow create: if isVerified() && isValidMessage(incoming());
      allow update: if isVerified() && (
        isAdmin() ||
        (
          (existing().recipientId == request.auth.uid || (existing().recipientId == 'global' && existing().senderId != request.auth.uid)) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['read']) &&
          incoming().read == true
        )
      );
      allow delete: if isAdmin();
    }
  }
}
