rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
             request.auth.token.email == 'riteshgarad4@gmail.com' ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin')
      );
    }
    function isDeptHead(dept) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Dept Head' &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department == dept;
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isValidString(val, max) { return val is string && val.size() <= max; }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isAdmin() || (
        isSignedIn() && isOwner(userId) && 
        incoming().keys().hasAll(['uid', 'email', 'name', 'role', 'department', 'isActive', 'createdAt']) &&
        (incoming().role == 'Volunteer' || incoming().role == 'Staff Operative' || request.auth.token.email == 'riteshgarad4@gmail.com')
      );
      allow update: if isAdmin() || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'department']));
      allow delete: if isAdmin();
    }

    // --- Projects ---
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Simplified for now as many roles can propose
      allow update: if (
        isAdmin() || 
        (isDeptHead(existing().department) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'budget_status', 'rejection_reason'])) ||
        (isOwner(existing().creator_id) && existing().status == 'pending_dept_review' && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'budget', 'department', 'lead_name']))
      );
      
      match /milestones/{milestoneId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isDeptHead(get(/databases/$(database)/documents/projects/$(projectId)).data.department);
      }
    }

    // --- Tasks ---
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isAdmin() || 
        isDeptHead(existing().assignedDept) ||
        (isOwner(existing().assignedVolunteerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'completedAt', 'relatedDocId']))
      );
    }

    // --- Volunteers ---
    match /volunteers/{volunteerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Documentation ---
    match /documents/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if (
        isAdmin() || 
        isDeptHead('Operations') || 
        isDeptHead('Marketing') ||
        (isOwner(existing().uploaderId) && existing().status == 'pending')
      );
    }

    // --- Finance & Transactions ---
    match /transactions/{tId} {
      allow read: if isAdmin() || isDeptHead('Finance');
      allow create: if isAdmin() || isDeptHead('Finance') || isDeptHead('Operations');
      allow update: if isAdmin() || isDeptHead('Finance');
    }

    match /finance_requests/{rId} {
      allow read, write: if isAdmin() || isDeptHead('Finance');
    }

    match /budget_requests/{rId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isDeptHead('Finance') || isDeptHead(incoming().department);
    }

    // --- Campaigns ---
    match /campaigns/{cId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isDeptHead('Marketing') || isDeptHead('Social Media') || isDeptHead('Public Relations');
    }

    // --- Donors & Donations ---
    match /donors/{dId} {
      allow read: if isAdmin() || isDeptHead('Finance') || isDeptHead('Public Relations');
      allow write: if isAdmin() || isDeptHead('Finance');
    }

    match /donations/{dId} {
      allow read: if isAdmin() || isDeptHead('Finance');
      allow create: if isSignedIn();
    }

    // --- Misc ---
    match /activity_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
    
    match /work_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isDeptHead(existing().department);
    }

    match /volunteer_applications/{appId} {
      allow read: if isAdmin() || isDeptHead('HR');
      allow create: if true; // Public access
      allow update: if isAdmin() || isDeptHead('HR');
    }

    match /volunteer_certificates/{certId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isDeptHead('HR');
    }
  }
}
