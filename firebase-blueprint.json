{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Represents an NGO project or initiative.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "tag": { "type": "string", "enum": ["Health", "Education", "Environment", "Community", "Technology"] },
        "status": { "type": "string", "enum": ["pending_dept_review", "pending_admin_review", "approved", "rejected", "active", "completed", "on_hold"] },
        "phase": { "type": "number" },
        "progress": { "type": "number" },
        "rejection_reason": { "type": "string" },
        "timeline": { "type": "string" },
        "department": { "type": "string" },
        "lead_name": { "type": "string" },
        "budget": { "type": "string" },
        "budget_status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "created_at": { "type": "string", "format": "date-time" },
        "creator_id": { "type": "string" }
      },
      "required": ["name", "status", "creator_id", "department"]
    },
    "FinanceRequest": {
      "title": "Finance Request",
      "description": "Automatically generated budget request for approved projects.",
      "type": "object",
      "properties": {
        "project_id": { "type": "string" },
        "project_name": { "type": "string" },
        "amount": { "type": "string" },
        "requested_at": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "disbursed", "rejected"] }
      },
      "required": ["project_id", "amount", "status"]
    },
    "Task": {
      "title": "Task",
      "description": "A specific task or action item within a project.",
      "type": "object",
      "properties": {
        "project_id": { "type": "string" },
        "title": { "type": "string" },
        "department": { "type": "string" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "assigned_to": { "type": "string" },
        "due_date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["todo", "inprogress", "completed"] },
        "task_type": { "type": "string", "enum": ["execution", "approval"] },
        "is_locked": { "type": "boolean" },
        "decision": { "type": "string", "enum": ["approved", "rejected"] },
        "created_at": { "type": "string", "format": "date-time" },
        "creator_id": { "type": "string" }
      },
      "required": ["title", "status", "creator_id"]
    },
    "Volunteer": {
      "title": "Volunteer",
      "description": "An NGO operative or member.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "department": { "type": "string" },
        "skills": { "type": "string" },
        "hours": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["name", "email", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notification for the user.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "type": { "type": "string", "enum": ["deadline", "milestone", "system", "approval"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" },
        "relatedId": { "type": "string" }
      },
      "required": ["user_id", "title", "message", "isRead"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial record (income or expense) for the NGO.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "projectID": { "type": "string" },
        "donationType": { "type": "string", "enum": ["One-time", "Monthly", "Corporate", "In-kind", "N/A"] },
        "expenditureType": { "type": "string", "enum": ["Procurement", "Travel", "Event Setup", "Marketing", "N/A"] },
        "paymentMethod": { "type": "string", "enum": ["Bank Transfer", "Cash", "UPI", "Online Gateway"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "cleared"] },
        "receiptURL": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["type", "amount", "category", "status", "date", "createdBy"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "A fundraising campaign for the NGO.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "goal_amount": { "type": "number" },
        "current_raised": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "pending_head", "pending_admin", "active", "completed"] },
        "media_urls": { "type": "array", "items": { "type": "string" } },
        "impact_story_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["title", "goal_amount", "status", "created_by"]
    },
    "Donor": {
      "title": "Donor",
      "description": "A supporter who provides financial contributions.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "total_donated": { "type": "number" },
        "tier": { "type": "string", "enum": ["Bronze", "Silver", "Gold", "Platinum"] },
        "last_donation_date": { "type": "string", "format": "date-time" },
        "frequency": { "type": "string", "enum": ["one-time", "monthly", "yearly"] },
        "join_date": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "tier"]
    },
    "Donation": {
      "title": "Donation",
      "description": "An individual financial contribution record.",
      "type": "object",
      "properties": {
        "donor_id": { "type": "string" },
        "amount": { "type": "number" },
        "campaign_id": { "type": "string" },
        "is_recurring": { "type": "boolean" },
        "status": { "type": "string", "enum": ["captured", "failed"] },
        "donor_visibility": { "type": "string", "enum": ["public", "anonymous"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "payment_method": { "type": "string" }
      },
      "required": ["donor_id", "amount", "status", "timestamp"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of NGO projects."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Flat collection of tasks, linked by project_id."
    },
    "/volunteers/{volunteerId}": {
      "schema": "Volunteer",
      "description": "Collection of NGO members."
    },
    "/finance_requests/{requestId}": {
      "schema": "FinanceRequest",
      "description": "Automated budget allocation requests."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Per-user notifications."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial ledger for the NGO."
    },
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Marketing fundraising campaigns."
    },
    "/donors/{donorId}": {
      "schema": "Donor",
      "description": "CRM for NGO supporters."
    },
    "/donations/{donationId}": {
      "schema": "Donation",
      "description": "Individual donation transaction records."
    }
  }
}
