{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "System user with role and department assignment",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Department Head", "Volunteer", "Staff Operative", "Finance Head", "HR Head", "Project Head", "Marketing Head"] },
        "department": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "fcmToken": { "type": "string" },
        "onesignalId": { "type": "string" },
        "lastSignalUpdate": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "department", "isActive", "createdAt"]
    },
    "Meeting": {
      "title": "Mission Pulse",
      "description": "Scheduled meeting or mission event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "start": { "type": "object" },
        "end": { "type": "object" },
        "type": { "type": "string", "enum": ["global", "mission", "departmental"] },
        "dept": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "attendees": { "type": "object" }
      },
      "required": ["title", "start", "end", "type", "creatorId"]
    },
    "Attendance": {
      "title": "Mission Attendance",
      "description": "Volunteer punch-in/out record with geolocation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "projectId": { "type": "string" },
        "missionName": { "type": "string" },
        "location": { 
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "punchIn": { "type": "object" },
        "punchOut": { "type": "object" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "durationMinutes": { "type": "number" }
      },
      "required": ["userId", "projectId", "punchIn", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/schedule/{eventId}": {
      "schema": "Meeting",
      "description": "Scheduled mission pulses and meetings"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Volunteer mission punch records"
    }
  }
}
